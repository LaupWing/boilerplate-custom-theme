{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"apiVersion": 3,
	"name": "snel/content-section",
	"version": "1.0.0",
	"title": "Content Section",
	"category": "snel",
	"icon": "welcome-write-blog",
	"description": "Flexible content section with InnerBlocks and chunk-based multilingual support. Custom blocks render independently.",
	"keywords": ["content", "section", "rich", "innerblocks"],
	"textdomain": "snel",
	"editorScript": "file:./index.js",
	"render": "file:./render.php",
	"supports": {
		"align": ["full"]
	},
	"attributes": {
		"align": {
			"type": "string",
			"default": "full"
		},
		"backgroundColor": {
			"type": "string",
			"default": "white"
		},
		"maxWidth": {
			"type": "string",
			"default": "narrow",
			"enum": ["narrow", "wide"]
		},
		"contentTranslations": {
			"type": "object",
			"default": {}
		},
		"verticalPadding": {
			"type": "boolean",
			"default": true
		}
	}
}
