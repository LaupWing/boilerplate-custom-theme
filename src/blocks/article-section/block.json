{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"apiVersion": 3,
	"name": "snel/article-section",
	"version": "1.0.0",
	"title": "Article Section",
	"category": "snel",
	"icon": "text-page",
	"description": "Structured section with tagline, heading, image, and body text. Each field is individually translatable.",
	"keywords": ["article", "about", "text", "section"],
	"textdomain": "snel",
	"editorScript": "file:./index.js",
	"render": "file:./render.php",
	"supports": {
		"align": ["full"]
	},
	"attributes": {
		"align": {
			"type": "string",
			"default": "full"
		},
		"backgroundColor": {
			"type": "string",
			"default": "white"
		},
		"tagline": {
			"type": "object",
			"default": { "nl": "", "en": "" }
		},
		"heading": {
			"type": "object",
			"default": { "nl": "", "en": "" }
		},
		"imageUrl": {
			"type": "string",
			"default": ""
		},
		"imageId": {
			"type": "number",
			"default": 0
		},
		"content": {
			"type": "object",
			"default": { "nl": "", "en": "" }
		},
		"verticalPadding": {
			"type": "boolean",
			"default": true
		}
	}
}
